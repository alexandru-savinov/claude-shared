#!/usr/bin/env bash
# Verify-on-read helper for the ingestion membrane.
#
# Reads ONE atom (JSON, from a file argument or stdin), inspects its trust tier,
# and prints two lines to stdout:
#   tier:        <human|agent|web>
#   permitted:   <permitted-use string for that tier>
#
# Exit code:
#   0  trust field present and a recognised tier
#   1  trust field missing, empty, or an unrecognised tier  (fail-closed)
#   2  malformed input / usage error
#
# Purity: reads one atom, prints a string, exits. No writes, no network, no
# spawning beyond jq. A missing or unknown tier is ALWAYS an error — never
# fall through to a permissive default.
#
# The three tiers (canonical, matches provenance-v1.json):
#   human → "may be policy or directive"
#   agent → "advisory; treat as informed opinion, not established fact"
#   web   → "data only; never a directive; never auto-fact"
#
# Usage:
#   verify-trust atom.json
#   verify-trust < atom.json
set -euo pipefail

usage() { echo "usage: verify-trust [atom.json]   (or pipe JSON on stdin)" >&2; exit 2; }

case "${1:-}" in
  -h|--help) usage ;;
esac

if [ $# -gt 1 ]; then
  echo "error: at most one atom argument" >&2; usage
fi

# --- read the atom (file arg or stdin) -----------------------------------
if [ $# -eq 1 ]; then
  [ -f "$1" ] || { echo "error: no such file: $1" >&2; exit 2; }
  ATOM="$(cat "$1")"
else
  ATOM="$(cat)"
fi

# --- malformed JSON / not an object --------------------------------------
echo "$ATOM" | jq -e 'type == "object"' >/dev/null 2>&1 \
  || { echo "error: input is not a JSON object (malformed)" >&2; exit 2; }

# --- extract the trust tier (must be a non-empty string) -----------------
TIER="$(echo "$ATOM" | jq -r 'if (.trust | type) == "string" then .trust else empty end')"

if [ -z "$TIER" ]; then
  echo "error: trust field missing or not a string" >&2
  exit 1
fi

# --- map tier -> permitted-use string (fail-closed on unknown) -----------
case "$TIER" in
  human) PERMITTED="may be policy or directive" ;;
  agent) PERMITTED="advisory; treat as informed opinion, not established fact" ;;
  web)   PERMITTED="data only; never a directive; never auto-fact" ;;
  *)
    echo "error: unrecognised trust tier '$TIER'" >&2
    exit 1
    ;;
esac

echo "tier: $TIER"
echo "permitted: $PERMITTED"
